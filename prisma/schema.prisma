generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id Int @id @default(autoincrement())
  email String @unique
  senha String

}

model Paciente {
  id           Int       @id @default(autoincrement())
  nome         String
  telefone     String
  ativo        Boolean   @default(true)
  codigoBarras String    @unique
  createdAt    DateTime  @default(now())
  presencas    Presenca[]
  observacoes Observacao[]

}

model Instrutor {
  id Int @id @default(autoincrement())
  nome String 
  telefone String
  email String @unique
  ativo Boolean @default(true)
  codigoBarras String @unique
  createdAt DateTime @default(now())
  presencas Presenca[]  

}

model Trabalhador {
  id Int @id @default(autoincrement())
  nome String 
  telefone String
  email String @unique
  ativo Boolean @default(true)
  codigoBarras String @unique
  createdAt DateTime @default(now())
  presencas Presenca[]  

}

model Aluno {
  id           Int       @id @default(autoincrement())
  nome         String
  blocoEstudo  String
  telefone     String
  ativo        Boolean   @default(true)
  codigoBarras String    @unique
  createdAt    DateTime  @default(now())
  presencas    Presenca[]
}

model Presenca {
  id  Int @id @default(autoincrement())
  tipo  TipoPessoa
  horario DateTime @default(now())
  codigoBarras String

  pacienteId  Int?
  instrutorId Int?
  trabalhadorId Int?
  alunoId Int?

  paciente Paciente?  @relation(fields: [pacienteId], references: [id])
  instrutor Instrutor?  @relation(fields: [instrutorId], references: [id])
  trabalhador Trabalhador?  @relation(fields: [trabalhadorId], references: [id])
  aluno Aluno?  @relation(fields: [alunoId], references: [id])

}

model VinculoPessoa {
  id             Int        @id @default(autoincrement())
  codigoBarras   String     // código do crachá principal
  tipoPrincipal  TipoPessoa
  codigoSecund   String     // código do vínculo secundário
  tipoSecund     TipoPessoa
  @@unique([codigoBarras, tipoSecund])
}

model Observacao {
  id         Int      @id @default(autoincrement())
  pacienteId Int
  numero     Int      // 1, 2, 3 ou 4
  descricao  String
  data       DateTime @default(now())
  paciente   Paciente @relation(fields: [pacienteId], references: [id])
}

enum TipoPessoa {
  paciente
  instrutor
  trabalhador
  aluno

}